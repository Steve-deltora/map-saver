{
  "manifest_version": 3,
  "name": "地圖收藏助手 Map Saver",
  "version": "1.0.0",
  "description": "從 IG、FB、YouTube 等貼文中抽取店名，自動加入 Google Maps 儲存清單",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://maps.google.com/*",
    "https://www.instagram.com/*",
    "https://www.facebook.com/*",
    "https://www.youtube.com/*",
    "https://www.tiktok.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.threads.net/*",
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "地圖收藏助手",
    "default_icon": "icons/icon.png"
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["selection_trigger.js"],
      "run_at": "document_idle",
      "exclude_matches": ["https://www.google.com/maps/*", "https://maps.google.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
